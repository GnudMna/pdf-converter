<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="ThemeMarker">Dark</sys:String>

    <!-- 背景・サーフェス -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF0B1120" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF161E2E" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#FF2A3346" />

    <!-- テキスト -->
    <SolidColorBrush x:Key="SectionTitleForegroundBrush" Color="#FFF1F5F9" />
    <SolidColorBrush x:Key="FieldLabelForegroundBrush" Color="#FFCBD5E1" />
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#FF94A3B8" />
    <SolidColorBrush x:Key="ControlForegroundBrush" Color="#FFCBD5E1" />

    <!-- アクセント -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FF6366F1" />

    <!-- プライマリボタン -->
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#FF6366F1" />
    <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#FF818CF8" />
    <SolidColorBrush x:Key="PrimaryButtonPressedBrush" Color="#FF4F46E5" />
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFFFF" />

    <!-- セカンダリボタン -->
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#FF273043" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#FF323D54" />
    <SolidColorBrush x:Key="SecondaryButtonPressedBrush" Color="#FF3B475F" />
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#FFE2E8F0" />

    <!-- 無効ボタン -->
    <SolidColorBrush x:Key="DisabledButtonBackgroundBrush" Color="#FF334155" />
    <SolidColorBrush x:Key="DisabledButtonForegroundBrush" Color="#FF64748B" />

    <!-- キャンセルボタン -->
    <SolidColorBrush x:Key="CancelButtonBackgroundBrush" Color="#FF3B1D1D" />
    <SolidColorBrush x:Key="CancelButtonHoverBrush" Color="#FF4D2525" />
    <SolidColorBrush x:Key="CancelButtonPressedBrush" Color="#FF5C2C2C" />
    <SolidColorBrush x:Key="CancelButtonBorderBrush" Color="#FF7F1D1D" />
    <SolidColorBrush x:Key="CancelButtonForegroundBrush" Color="#FFFCA5A5" />

    <!-- 入力欄 -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FF0E1626" />
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#FFE2E8F0" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#FF3A4762" />
    <SolidColorBrush x:Key="InputHoverBorderBrush" Color="#FF4A5878" />
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#FF6366F1" />
    <SolidColorBrush x:Key="CheckBoxBorderBrush" Color="#FF4A5878" />

    <!-- プレビュー -->
    <SolidColorBrush x:Key="PreviewAreaBackgroundBrush" Color="#FF0A0F1C" />
    <SolidColorBrush x:Key="PreviewAreaBorderBrush" Color="#FF2A3346" />

    <!-- ステータスバー -->
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#FF161E2E" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#FFCBD5E1" />
    <SolidColorBrush x:Key="StatusInfoBackgroundBrush" Color="#FF1E1B4B" />
    <SolidColorBrush x:Key="StatusInfoBorderBrush" Color="#FF4338CA" />
    <SolidColorBrush x:Key="StatusInfoForegroundBrush" Color="#FFC7D2FE" />
    <SolidColorBrush x:Key="StatusProgressBackgroundBrush" Color="#FF1E1B4B" />
    <SolidColorBrush x:Key="StatusProgressBorderBrush" Color="#FF4F46E5" />
    <SolidColorBrush x:Key="StatusProgressForegroundBrush" Color="#FFA5B4FC" />
    <SolidColorBrush x:Key="StatusSuccessBackgroundBrush" Color="#FF052E1C" />
    <SolidColorBrush x:Key="StatusSuccessBorderBrush" Color="#FF065F46" />
    <SolidColorBrush x:Key="StatusSuccessForegroundBrush" Color="#FF6EE7B7" />
    <SolidColorBrush x:Key="StatusWarningBackgroundBrush" Color="#FF3B2F14" />
    <SolidColorBrush x:Key="StatusWarningBorderBrush" Color="#FF92400E" />
    <SolidColorBrush x:Key="StatusWarningForegroundBrush" Color="#FFFCD34D" />
    <SolidColorBrush x:Key="StatusErrorBackgroundBrush" Color="#FF3B1D1D" />
    <SolidColorBrush x:Key="StatusErrorBorderBrush" Color="#FF7F1D1D" />
    <SolidColorBrush x:Key="StatusErrorForegroundBrush" Color="#FFFCA5A5" />
    <SolidColorBrush x:Key="ValidationMessageForegroundBrush" Color="#FFFCA5A5" />

    <!-- プログレスバー -->
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="#FF273043" />
    <SolidColorBrush x:Key="ProgressBarForegroundBrush" Color="#FF6366F1" />

    <!-- コンボボックスポップアップ -->
    <SolidColorBrush x:Key="ComboBoxPopupBackgroundBrush" Color="#FF161E2E" />

    <!-- スクロールバー -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#FF3A4762" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#FF4A5878" />

    <!-- ドラッグ&ドロップ オーバーレイ -->
    <SolidColorBrush x:Key="DropOverlayBackgroundBrush" Color="#F00E1A33" />
    <SolidColorBrush x:Key="DropOverlayBorderBrush" Color="#FF6366F1" />
    <SolidColorBrush x:Key="DropOverlayForegroundBrush" Color="#FFC7D2FE" />

    <!-- 処理中オーバーレイ -->
    <SolidColorBrush x:Key="BusyOverlayBackgroundBrush" Color="#D9161E2E" />
    <SolidColorBrush x:Key="BusyOverlayForegroundBrush" Color="#FFCBD5E1" />
</ResourceDictionary>
