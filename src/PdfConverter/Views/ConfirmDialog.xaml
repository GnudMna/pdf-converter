<Window x:Class="PdfConverter.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="確認"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        MaxWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="24"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.22" ShadowDepth="4" Direction="270" Color="#FF1E293B" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- アイコン、タイトル、メッセージ -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <Border x:Name="IconBorder"
                        Width="40"
                        Height="40"
                        CornerRadius="20"
                        Background="{DynamicResource StatusWarningBackgroundBrush}"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top">
                    <Path x:Name="IconPath"
                          Width="20"
                          Height="20"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Fill="{DynamicResource StatusWarningForegroundBrush}"
                          Data="M12 2 L22 20 L2 20 Z M12 9 L12 14 M12 17 L12 17" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SectionTitleForegroundBrush}" />
                    <TextBlock x:Name="MessageText"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               LineHeight="20"
                               Foreground="{DynamicResource ControlForegroundBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- 詳細メッセージ -->
            <ScrollViewer Grid.Row="1"
                          MaxHeight="180"
                          Margin="0,0,0,20"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed"
                          x:Name="DetailScroll">
                <TextBlock x:Name="DetailText"
                           TextWrapping="Wrap"
                           FontSize="12"
                           LineHeight="18"
                           Foreground="{DynamicResource MutedForegroundBrush}" />
            </ScrollViewer>

            <!-- ボタン -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="NoButton"
                        Content="キャンセル"
                        MinWidth="100"
                        Margin="0,0,10,0"
                        Click="NoButton_Click"
                        Style="{StaticResource SecondaryButton}" />
                <Button x:Name="YesButton"
                        Content="はい"
                        MinWidth="100"
                        Click="YesButton_Click"
                        Style="{StaticResource PrimaryButton}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
