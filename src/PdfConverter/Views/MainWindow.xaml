<Window x:Class="PdfConverter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:PdfConverter.Converters"
        mc:Ignorable="d"
        Title="PDF Converter"
        Height="720"
        Width="980"
        Background="#FFF2F5FB"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AllowDrop="True"
        Drop="MainWindow_Drop">

    <Window.Resources>
        <!-- コンバーター -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />

        <!-- テキストスタイル -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF1E3A5F" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF334155" />
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#FF64748B" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF64748B" />
        </Style>

        <!-- レイアウトスタイル -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="BorderBrush" Value="#FFE2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" Opacity="0.08" ShadowDepth="2" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ボタンスタイル -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#FFF1F5F9" />
            <Setter Property="Foreground" Value="#FF1E3A5F" />
        </Style>
        <Style x:Key="SaveButton"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="#FF2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFCBD5E1" />
                    <Setter Property="Foreground" Value="#FF94A3B8" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CopyButton"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="MinHeight" Value="32" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFCBD5E1" />
                    <Setter Property="Foreground" Value="#FF94A3B8" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CancelButton"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="#FFE2E8F0" />
            <Setter Property="BorderBrush" Value="#FFCBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FF334155" />
        </Style>

        <!-- 入力スタイル -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#FFCBD5E1" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 設定パネル・プレビュー -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 入力・変換設定 -->
            <StackPanel Grid.Column="0">

                <!-- 入力情報 -->
                <Border Style="{StaticResource CardBorder}" Padding="18" Margin="0,0,0,18" MinWidth="340">
                    <StackPanel>
                        <TextBlock Text="入力情報" Style="{StaticResource SectionTitle}" />
                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="PDF ファイル" Style="{StaticResource FieldLabel}" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding FilePath}"
                                         LostFocus="FilePathTextBox_LostFocus"
                                         MinWidth="250"
                                         Margin="1,0,12,0" />
                                <Button Grid.Column="1"
                                        Content="参照"
                                        Width="50"
                                        Command="{Binding BrowseCommand}"
                                        Style="{StaticResource PrimaryButton}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 変換設定 -->
                <Border Style="{StaticResource CardBorder}" Padding="18" MinWidth="340">
                    <StackPanel>
                        <TextBlock Text="変換設定" Style="{StaticResource SectionTitle}" />

                        <!-- 出力解像度 -->
                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="出力解像度" Style="{StaticResource FieldLabel}" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                                <ComboBox Width="140"
                                          Margin="0,0,8,0"
                                          ItemsSource="{Binding ResolutionModeOptions}"
                                          SelectedValue="{Binding ResolutionMode}"
                                          SelectedValuePath="Mode"
                                          DisplayMemberPath="DisplayName" />
                                <TextBox Width="100"
                                         Margin="0,0,8,0"
                                         Text="{Binding ResolutionValue}" />
                                <TextBlock Text="px / DPI"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HintText}"
                                       Text="選択したモードに応じて、幅・高さ (px) または DPI を入力してください。" />
                        </StackPanel>

                        <!-- ページ情報 -->
                        <StackPanel Margin="0,18,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ページ情報" Style="{StaticResource FieldLabel}" />
                                <CheckBox Grid.Column="1"
                                          Content="全ページ保存"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsAllPagesSelected}" />
                            </Grid>
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HintText}"
                                       Text="保存するページを番号または範囲で指定できます。" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="対象ページ"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Width="160"
                                         Text="{Binding PageRange, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsAllPagesSelected, Converter={StaticResource InverseBooleanConverter}}" />
                            </Grid>
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HintText}"
                                       Text="例: 1,3-5"
                                       TextWrapping="NoWrap" />
                        </StackPanel>

                        <!-- アクションボタン -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    Margin="0,24,0,0">
                            <Button Content="画像として保存"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource SaveButton}" />
                            <Button Content="プレビューをコピー"
                                    Margin="12,0,0,0"
                                    Command="{Binding CopyToClipboardCommand}"
                                    Style="{StaticResource CopyButton}" />
                            <Button Content="キャンセル"
                                    Margin="12,0,0,0"
                                    Command="{Binding CancelCommand}"
                                    Style="{StaticResource CancelButton}"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- プレビュー -->
            <Border Grid.Column="1"
                    Style="{StaticResource CardBorder}"
                    Padding="18"
                    VerticalAlignment="Stretch">
                <Grid VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- プレビューヘッダー -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="プレビュー"
                                       Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{Binding PageIndicator}"
                                       FontSize="12"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource MutedText}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="表示ページ"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Style="{StaticResource FieldLabel}" />
                            <TextBox Width="72"
                                     Text="{Binding PageNumber, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                            <Button Content="表示"
                                    Width="80"
                                    Margin="8,0,16,0"
                                    Command="{Binding GoToPageCommand}"
                                    Style="{StaticResource SecondaryButton}" />
                            <Button Content="＜"
                                    Width="32"
                                    Margin="0,0,8,0"
                                    ToolTip="前のページに移動"
                                    Command="{Binding PreviousPageCommand}"
                                    Style="{StaticResource SecondaryButton}" />
                            <Button Content="＞"
                                    Width="32"
                                    ToolTip="次のページに移動"
                                    Command="{Binding NextPageCommand}"
                                    Style="{StaticResource SecondaryButton}" />
                        </StackPanel>
                    </Grid>

                    <!-- プレビュー画像 -->
                    <Border Grid.Row="1"
                            Background="#FFF8FAFC"
                            CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="#FFDDE5ED"
                            Margin="0,14,0,0"
                            Padding="12"
                            VerticalAlignment="Stretch">
                        <Grid VerticalAlignment="Stretch">
                            <Image Source="{Binding PreviewImage}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />
                            <TextBlock Text="プレビュー画像がここに表示されます。PDFを選択すると自動でプレビューが表示されます。"
                                       FontSize="14"
                                       Padding="24"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource MutedText}"
                                       Visibility="{Binding PreviewImage, Converter={StaticResource NullToVisibilityConverter}}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

        </Grid>

        <!-- ステータスバー -->
        <StackPanel Grid.Row="1"
                    Margin="0,18,0,0">
            <ProgressBar Minimum="0"
                         Maximum="100"
                         Height="14"
                         Margin="0,0,0,10"
                         Value="{Binding ProgressValue}"
                         Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}" />
            <Border Padding="14"
                    Background="White"
                    CornerRadius="14"
                    BorderBrush="#FFE2E8F0"
                    BorderThickness="1">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#FF334155"
                           VerticalAlignment="Center" />
            </Border>
        </StackPanel>

    </Grid>
</Window>
