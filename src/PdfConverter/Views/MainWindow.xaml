<Window x:Class="PdfConverter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:PdfConverter.Converters"
        xmlns:behaviors="clr-namespace:PdfConverter.Views.Behaviors"
        xmlns:models="clr-namespace:PdfConverter.Models"
        xmlns:views="clr-namespace:PdfConverter.Views"
        mc:Ignorable="d"
        Title="PDF Converter"
        Icon="/Assets/app.ico"
        Height="920"
        Width="800"
        MinHeight="600"
        MinWidth="680"
        Background="{DynamicResource WindowBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        behaviors:FileDropBehavior.IsEnabled="True">

    <Window.InputBindings>
        <KeyBinding Key="Left"
                    Modifiers="Control"
                    Command="{Binding PreviousPageCommand}" />
        <KeyBinding Key="Right"
                    Modifiers="Control"
                    Command="{Binding NextPageCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </Window.Resources>

    <Grid>
        <!-- メインコンテンツ -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ヘッダー -->
            <Border Grid.Row="0"
                    Margin="0,0,0,18"
                    Padding="0,0,0,16"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="48"
                                Height="48"
                                CornerRadius="12"
                                Background="{DynamicResource PreviewAreaBackgroundBrush}"
                                BorderBrush="{DynamicResource PreviewAreaBorderBrush}"
                                BorderThickness="1"
                                Margin="0,0,14,0">
                            <Image Source="/Assets/app-icon.png"
                                   Width="32"
                                   Height="32"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="PDF Converter"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SectionTitleForegroundBrush}" />
                            <TextBlock Text="PDF / Word を画像としてエクスポート"
                                       Margin="0,3,0,0"
                                       Style="{StaticResource HintText}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Style="{StaticResource PreviewToolbarBorder}"
                            VerticalAlignment="Center"
                            ToolTip="外観テーマ">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Style="{StaticResource ThemeModeRadioButton}"
                                         GroupName="ThemeMode"
                                         IsChecked="{Binding IsLightThemeSelected}"
                                         ToolTip="ライト">
                                <Path Style="{StaticResource ThemeModeIconPath}"
                                      Data="M12 3.5 L12 6.5 M12 17.5 L12 20.5 M3.5 12 L6.5 12 M17.5 12 L20.5 12 M5.8 5.8 L7.9 7.9 M16.1 16.1 L18.2 18.2 M5.8 18.2 L7.9 16.1 M16.1 7.9 L18.2 5.8 M12 8.5 A3.5 3.5 0 1 0 12 15.5 A3.5 3.5 0 1 0 12 8.5" />
                            </RadioButton>
                            <RadioButton Style="{StaticResource ThemeModeRadioButton}"
                                         GroupName="ThemeMode"
                                         Margin="2,0,0,0"
                                         IsChecked="{Binding IsDarkThemeSelected}"
                                         ToolTip="ダーク">
                                <Path Style="{StaticResource ThemeModeIconPath}"
                                      Data="M15 5.5 A7 7 0 1 1 9 18.5 A5.5 5.5 0 1 0 15 5.5" />
                            </RadioButton>
                            <RadioButton Style="{StaticResource ThemeModeRadioButton}"
                                         GroupName="ThemeMode"
                                         Margin="2,0,0,0"
                                         IsChecked="{Binding IsSystemThemeSelected}"
                                         ToolTip="システムに合わせる">
                                <Path Style="{StaticResource ThemeModeIconPath}"
                                      Data="M5 6.5 L19 6.5 L19 15.5 L5 15.5 Z M8 17.5 L16 17.5 M10 17.5 L10 19.5 L14 19.5 L14 17.5" />
                            </RadioButton>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 設定パネル・プレビュー -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"
                                      MinWidth="320"
                                      MaxWidth="480" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*"
                                      MinWidth="320" />
                </Grid.ColumnDefinitions>

                <!-- 入力・変換設定 -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,6,0">
                    <StackPanel>

                        <!-- 入力情報 -->
                        <Border Style="{StaticResource CardBorder}" Padding="18" Margin="0,0,0,18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Style="{StaticResource SectionHeaderAccent}" />
                                    <TextBlock Text="入力情報" Style="{StaticResource SectionTitle}" />
                                </StackPanel>
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="ファイル (PDF / Word)"
                                               Style="{StaticResource FieldLabel}"
                                               ToolTip="PDF または Word ファイルのパス。入力後 Enter またはフォーカスを外すと読み込みます。ドラッグ&amp;ドロップでも選択できます。" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding FilePath}"
                                                 ToolTip="入力後 Enter またはフォーカスを外すと読み込みます"
                                                 behaviors:InvokeCommandBehavior.LostFocusCommand="{Binding LoadPdfFromPathCommand}"
                                                 behaviors:InvokeCommandBehavior.EnterKeyCommand="{Binding LoadPdfFromPathCommand}"
                                                 IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                                 Margin="1,0,12,0" />
                                        <Button Grid.Column="1"
                                                Content="参照"
                                                MinWidth="64"
                                                Command="{Binding BrowseCommand}"
                                                Style="{StaticResource PrimaryButton}" />
                                    </Grid>
                                </StackPanel>

                                <Expander Margin="0,14,0,0"
                                          Style="{StaticResource OptionalSectionExpander}"
                                          IsExpanded="{Binding WordSettings.IsSectionExpanded}"
                                          ToolTip="Word ファイルを開いたときに使用する変換オプションです。">
                                    <Expander.Header>
                                        <TextBlock Text="Word 設定"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource FieldLabelForegroundBrush}" />
                                    </Expander.Header>
                                    <StackPanel>
                                        <TextBlock Text="Word → PDF 変換"
                                                   Style="{StaticResource FieldLabel}"
                                                   ToolTip="Word ファイルを PDF 化する際に使用するエンジンを選択します。" />
                                        <ComboBox Margin="0,8,0,0"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding WordSettings.BackendOptions}"
                                                  SelectedValue="{Binding WordSettings.Backend}"
                                                  SelectedValuePath="Backend"
                                                  DisplayMemberPath="DisplayName" />
                                        <StackPanel Margin="0,10,0,0"
                                                    Visibility="{Binding WordSettings.IsLibreOfficePathVisible, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="LibreOffice 実行ファイル"
                                                       Style="{StaticResource FieldLabel}"
                                                       ToolTip="空欄の場合は一般的なインストール先から soffice.exe を自動検出します。" />
                                            <TextBox Margin="0,8,0,0"
                                                     Text="{Binding WordSettings.LibreOfficePath, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <TextBlock Margin="0,14,0,0"
                                                   Text="PDF 形式"
                                                   Style="{StaticResource FieldLabel}"
                                                   ToolTip="PDF/A-1 は長期保存向けの形式です。" />
                                        <ComboBox Margin="0,8,0,0"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding WordSettings.PdfFormatOptions}"
                                                  SelectedValue="{Binding WordSettings.PdfFormat}"
                                                  SelectedValuePath="Format"
                                                  DisplayMemberPath="DisplayName" />
                                        <TextBlock Margin="0,14,0,0"
                                                   Text="出力最適化"
                                                   Style="{StaticResource FieldLabel}"
                                                   ToolTip="オンライン向けはファイルサイズを抑えます。" />
                                        <ComboBox Margin="0,8,0,0"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding WordSettings.OptimizeForOptions}"
                                                  SelectedValue="{Binding WordSettings.OptimizeFor}"
                                                  SelectedValuePath="OptimizeFor"
                                                  DisplayMemberPath="DisplayName" />
                                        <CheckBox Margin="0,14,0,0"
                                                  Content="しおり (見出し) を出力"
                                                  IsChecked="{Binding WordSettings.ExportBookmarks}"
                                                  ToolTip="Word 文書の見出しスタイルから PDF のしおりを作成します。" />
                                        <CheckBox Margin="0,10,0,0"
                                                  Content="コメントを含める"
                                                  IsChecked="{Binding WordSettings.ExportComments}"
                                                  ToolTip="Word 文書のコメントを PDF に出力します。" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <!-- 変換設定 -->
                        <Border Style="{StaticResource CardBorder}" Padding="18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Style="{StaticResource SectionHeaderAccent}" />
                                    <TextBlock Text="変換設定" Style="{StaticResource SectionTitle}" />
                                </StackPanel>

                                <!-- 出力形式 -->
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="出力形式"
                                               Style="{StaticResource FieldLabel}"
                                               ToolTip="JPEG / PNG / BMP から選択します。" />
                                    <ComboBox Margin="0,8,0,0"
                                              HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding ExportSettings.OutputImageFormatOptions}"
                                              SelectedValue="{Binding ExportSettings.OutputImageFormat}"
                                              SelectedValuePath="Format"
                                              DisplayMemberPath="DisplayName" />
                                </StackPanel>

                                <!-- 出力解像度 -->
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="出力解像度"
                                               Style="{StaticResource FieldLabel}"
                                               ToolTip="選択したモードに応じて、幅・高さ (px) または DPI を入力してください。" />
                                    <Border Style="{StaticResource SettingValueBorder}">
                                        <StackPanel>
                                            <Grid VerticalAlignment="Center" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0"
                                                          ItemsSource="{Binding ExportSettings.ResolutionModeOptions}"
                                                          SelectedValue="{Binding ExportSettings.ResolutionMode}"
                                                          SelectedValuePath="Mode"
                                                          DisplayMemberPath="DisplayName"
                                                          Width="85" />
                                                <TextBox Grid.Column="2"
                                                         Text="{Binding ExportSettings.ResolutionValue}"
                                                         Width="80"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="px / DPI"
                                                           Margin="4,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource MutedText}" />
                                            </Grid>
                                            <TextBlock Text="{Binding ExportSettings.ResolutionValidationMessage}"
                                                       Style="{StaticResource ValidationMessage}"
                                                       Visibility="{Binding ExportSettings.ResolutionValidationMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- 保存ページ -->
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="保存ページ" Style="{StaticResource FieldLabel}" />
                                    <Border Style="{StaticResource SettingValueBorder}">
                                        <StackPanel>
                                            <CheckBox Content="全ページを保存"
                                                      IsChecked="{Binding ExportSettings.IsAllPagesSelected}" />
                                            <StackPanel Margin="0,10,0,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ExportSettings.IsAllPagesSelected}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="ページ番号または範囲"
                                                           Style="{StaticResource FieldLabel}"
                                                           ToolTip="例: 1,3-5" />
                                                <TextBox Margin="0,6,0,0"
                                                         ToolTip="例: 1,3-5"
                                                         Text="{Binding ExportSettings.PageRange, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="{Binding ExportSettings.PageRangeValidationMessage}"
                                                           Style="{StaticResource ValidationMessage}"
                                                           Visibility="{Binding ExportSettings.PageRangeValidationMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- 透明度 -->
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="透明度"
                                               Style="{StaticResource FieldLabel}"
                                               ToolTip="オフの場合は白背景で合成します。JPEG では透明度を保持できません。" />
                                    <CheckBox Margin="0,8,0,0"
                                              Content="透明度を保持"
                                              IsChecked="{Binding ExportSettings.PreserveTransparency}"
                                              IsEnabled="{Binding ExportSettings.IsTransparencySelectable}"
                                              ToolTip="オフの場合は白背景で合成します。JPEG では透明度を保持できません。" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <GridSplitter Grid.Column="1"
                              Style="{StaticResource PanelGridSplitter}" />

                <!-- プレビュー -->
                <Border Grid.Column="2"
                        Style="{StaticResource CardBorder}"
                        Padding="18"
                        VerticalAlignment="Stretch">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- プレビュータイトル・ページ移動 -->
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Rectangle Style="{StaticResource SectionHeaderAccent}" />
                                <TextBlock Text="プレビュー"
                                           Style="{StaticResource SectionTitle}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PageIndicator}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPageNavigationVisible}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Border Grid.Column="1"
                                    Style="{StaticResource PreviewToolbarBorder}"
                                    Visibility="{Binding IsPageNavigationVisible, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <Button Width="30"
                                            Padding="0"
                                            Margin="0,0,4,0"
                                            ToolTip="前のページ (Ctrl+←)"
                                            Command="{Binding PreviousPageCommand}"
                                            Style="{StaticResource CompactToolbarButton}">
                                        <Path Width="8"
                                              Height="12"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M8 2 L2 7 L8 12"
                                              Stroke="{DynamicResource SecondaryButtonForegroundBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent" />
                                    </Button>
                                    <TextBox MinWidth="{Binding PageNumberInputMinWidth}"
                                             MaxWidth="140"
                                             Style="{StaticResource CompactTextBox}"
                                             Text="{Binding PageNumber, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="ページ番号を入力して Enter"
                                             HorizontalContentAlignment="Right"
                                             IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                             behaviors:InvokeCommandBehavior.EnterKeyCommand="{Binding GoToPageCommand}" />
                                    <TextBlock Text="/"
                                               Margin="4,0"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding PageCount}"
                                               MinWidth="{Binding PageCountDisplayMinWidth}"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource MutedText}" />
                                    <Button Width="30"
                                            Padding="0"
                                            Margin="4,0,0,0"
                                            ToolTip="次のページ (Ctrl+→)"
                                            Command="{Binding NextPageCommand}"
                                            Style="{StaticResource CompactToolbarButton}">
                                        <Path Width="8"
                                              Height="12"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M2 2 L8 7 L2 12"
                                              Stroke="{DynamicResource SecondaryButtonForegroundBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent" />
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- プレビュー画像 -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource PreviewAreaBackgroundBrush}"
                                CornerRadius="12"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource PreviewAreaBorderBrush}"
                                Margin="0,14,0,0"
                                Padding="12">
                            <Grid VerticalAlignment="Stretch">
                                <Image Source="{Binding PreviewImage}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Opacity" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="Opacity" Value="0.35" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding PreviewImage}" Value="{x:Null}" />
                                                        <Condition Binding="{Binding IsBusy}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Path Width="48"
                                          Height="48"
                                          Margin="0,0,0,14"
                                          HorizontalAlignment="Center"
                                          Stretch="Uniform"
                                          Fill="{DynamicResource MutedForegroundBrush}"
                                          Opacity="0.7"
                                          Data="M6 2 L14 2 L20 8 L20 22 L6 22 Z M14 2 L14 8 L20 8" />
                                    <TextBlock Text="プレビュー画像がここに表示されます"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Text="ファイルを選択またはドラッグ&amp;ドロップすると自動で表示されます"
                                               FontSize="12"
                                               Margin="0,6,0,0"
                                               TextAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource HintText}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ページ番号バリデーション -->
                        <TextBlock Grid.Row="2"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Right"
                                   Text="{Binding PageNumberValidationMessage}"
                                   Style="{StaticResource ValidationMessage}"
                                   MaxWidth="320"
                                   Visibility="{Binding PageNumberValidationMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                    </Grid>
                </Border>

            </Grid>

            <!-- アクションバー -->
            <Border Grid.Row="2"
                    Margin="0,14,0,0"
                    Style="{StaticResource ActionBarBorder}">
                <WrapPanel Orientation="Horizontal"
                           HorizontalAlignment="Left">
                    <Button Content="画像として保存"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource SaveButton}"
                            Margin="0,0,10,0" />
                    <Button Content="PDF として保存"
                            Margin="0,0,10,0"
                            Command="{Binding SavePdfCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Visibility="{Binding IsSavePdfVisible, Converter={StaticResource BoolToVis}}" />
                    <Button Content="プレビューをコピー"
                            Margin="0,0,10,0"
                            Command="{Binding CopyToClipboardCommand}"
                            Style="{StaticResource CopyButton}" />
                    <Button Content="キャンセル"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource CancelButton}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                </WrapPanel>
            </Border>

            <!-- ステータスバー -->
            <Border Grid.Row="3"
                    Margin="0,14,0,0"
                    Padding="14,12"
                    CornerRadius="14"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource StatusInfoBackgroundBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource StatusInfoBorderBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Progress}">
                                <Setter Property="Background" Value="{DynamicResource StatusProgressBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource StatusProgressBorderBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Success}">
                                <Setter Property="Background" Value="{DynamicResource StatusSuccessBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource StatusSuccessBorderBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Warning}">
                                <Setter Property="Background" Value="{DynamicResource StatusWarningBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource StatusWarningBorderBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Error}">
                                <Setter Property="Background" Value="{DynamicResource StatusErrorBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource StatusErrorBorderBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Height="6"
                                 Margin="0,0,0,10"
                                 Value="{Binding ProgressValue}"
                                 IsIndeterminate="{Binding IsProgressIndeterminate}"
                                 Visibility="{Binding IsProgressBarVisible, Converter={StaticResource BoolToVis}}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Viewbox Grid.Column="0"
                                 Width="18"
                                 Height="18"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center">
                            <Grid Width="24" Height="24">
                                <Path Data="M12 2 A10 10 0 1 0 12 22 A10 10 0 1 0 12 2 M12 10 L12 11 M12 14 L12 16"
                                      Fill="{DynamicResource StatusInfoForegroundBrush}">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Progress}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Success}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Warning}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Error}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Data="M12 2 A10 10 0 1 0 12 22 A10 10 0 1 0 12 2 M7 12 L11 16 L17 9"
                                      Stroke="{DynamicResource StatusSuccessForegroundBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Visibility="Collapsed">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Success}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Data="M12 2 L22 20 L2 20 Z M12 9 L12 14 M12 17 L12 17"
                                      Fill="{DynamicResource StatusWarningForegroundBrush}"
                                      Visibility="Collapsed">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Warning}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Data="M12 2 A10 10 0 1 0 12 22 A10 10 0 1 0 12 2 M8 8 L16 16 M16 8 L8 16"
                                      Stroke="{DynamicResource StatusErrorForegroundBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      Visibility="Collapsed">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Error}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Visibility="Collapsed">
                                    <Path.Style>
                                        <Style TargetType="Path" BasedOn="{StaticResource StatusProgressSpinnerPath}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Progress}" />
                                                        <Condition Binding="{Binding IsProgressBarVisible}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Grid>
                        </Viewbox>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource StatusInfoForegroundBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Progress}">
                                            <Setter Property="Foreground" Value="{DynamicResource StatusProgressForegroundBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Success}">
                                            <Setter Property="Foreground" Value="{DynamicResource StatusSuccessForegroundBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Warning}">
                                            <Setter Property="Foreground" Value="{DynamicResource StatusWarningForegroundBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusKind}" Value="{x:Static models:StatusKind.Error}">
                                            <Setter Property="Foreground" Value="{DynamicResource StatusErrorForegroundBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ドラッグ&ドロップ オーバーレイ (デザイナーでは非表示。プレビューは DropOverlay.xaml を参照) -->
        <views:DropOverlay d:Visibility="Collapsed"
                           Visibility="{Binding IsDropOverlayVisible, Converter={StaticResource BoolToVis}}" />

    </Grid>
</Window>
