<Window x:Class="PdfConverter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:PdfConverter.Converters"
        mc:Ignorable="d"
        Title="PDF Converter"
        Height="845"
        Width="990"
        MinHeight="845"
        MinWidth="990"
        Background="{DynamicResource WindowBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AllowDrop="True"
        Drop="MainWindow_Drop">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="44"
                        Height="44"
                        CornerRadius="12"
                        Background="{DynamicResource PrimaryButtonBackgroundBrush}"
                        Margin="0,0,14,0">
                    <Viewbox Width="24" Height="24">
                        <Path Data="M 5 2 L 13 2 L 17 6 L 17 18 L 5 18 Z M 13 2 L 13 6 L 17 6 M 8 10 L 14 10 M 8 13 L 14 13 M 8 16 L 12 16"
                              Fill="Transparent"
                              Stroke="{DynamicResource PrimaryButtonForegroundBrush}"
                              StrokeThickness="1.4"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Viewbox>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="PDF Converter"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SectionTitleForegroundBrush}" />
                    <TextBlock Text="PDF を画像としてエクスポート"
                               Margin="0,3,0,0"
                               Style="{StaticResource HintText}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="外観"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Style="{StaticResource FieldLabel}" />
                <ComboBox Width="180"
                          ItemsSource="{Binding ThemeModeOptions}"
                          SelectedValue="{Binding ThemeMode}"
                          SelectedValuePath="Mode"
                          DisplayMemberPath="DisplayName" />
            </StackPanel>
        </Grid>

        <!-- 設定パネル・プレビュー -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 入力・変換設定 -->
            <StackPanel Grid.Column="0">

                <!-- 入力情報 -->
                <Border Style="{StaticResource CardBorder}" Padding="18" Margin="0,0,0,18" MinWidth="340">
                    <StackPanel>
                        <TextBlock Text="入力情報" Style="{StaticResource SectionTitle}" />
                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="PDF ファイル" Style="{StaticResource FieldLabel}" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding FilePath}"
                                         LostFocus="FilePathTextBox_LostFocus"
                                         MinWidth="250"
                                         Margin="1,0,12,0" />
                                <Button Grid.Column="1"
                                        Content="参照"
                                        Width="50"
                                        Command="{Binding BrowseCommand}"
                                        Style="{StaticResource PrimaryButton}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 変換設定 -->
                <Border Style="{StaticResource CardBorder}" Padding="18" MinWidth="340">
                    <StackPanel>
                        <TextBlock Text="変換設定" Style="{StaticResource SectionTitle}" />

                        <!-- 出力形式 -->
                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="出力ファイル形式" Style="{StaticResource FieldLabel}" />
                            <ComboBox Width="140"
                                      Margin="0,8,0,0"
                                      HorizontalAlignment="Left"
                                      ItemsSource="{Binding OutputImageFormatOptions}"
                                      SelectedValue="{Binding OutputImageFormat}"
                                      SelectedValuePath="Format"
                                      DisplayMemberPath="DisplayName" />
                        </StackPanel>

                        <!-- 透明度 -->
                        <StackPanel Margin="0,18,0,0">
                            <CheckBox Content="透明度を保持"
                                      IsChecked="{Binding PreserveTransparency}"
                                      IsEnabled="{Binding IsTransparencySelectable}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HintText}"
                                       Text="オフの場合は白背景で合成します。JPEG では透明度を保持できません。" />
                        </StackPanel>

                        <!-- 出力解像度 -->
                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="出力解像度" Style="{StaticResource FieldLabel}" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                                <ComboBox Width="140"
                                          Margin="0,0,8,0"
                                          ItemsSource="{Binding ResolutionModeOptions}"
                                          SelectedValue="{Binding ResolutionMode}"
                                          SelectedValuePath="Mode"
                                          DisplayMemberPath="DisplayName" />
                                <TextBox Width="100"
                                         Margin="0,0,8,0"
                                         Text="{Binding ResolutionValue}" />
                                <TextBlock Text="px / DPI"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HintText}"
                                       Text="選択したモードに応じて、幅・高さ (px) または DPI を入力してください。" />
                        </StackPanel>

                        <!-- ページ情報 -->
                        <StackPanel Margin="0,18,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ページ情報" Style="{StaticResource FieldLabel}" />
                                <CheckBox Grid.Column="1"
                                          Content="全ページ保存"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsAllPagesSelected}" />
                            </Grid>
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HintText}"
                                       Text="保存するページを番号または範囲で指定できます。" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="対象ページ"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Column="1"
                                         Width="160"
                                         Text="{Binding PageRange, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsAllPagesSelected, Converter={StaticResource InverseBooleanConverter}}" />
                            </Grid>
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HintText}"
                                       Text="例: 1,3-5"
                                       TextWrapping="NoWrap" />
                        </StackPanel>

                        <!-- アクションボタン -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    Margin="0,24,0,0">
                            <Button Content="画像として保存"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource SaveButton}" />
                            <Button Content="プレビューをコピー"
                                    Margin="12,0,0,0"
                                    Command="{Binding CopyToClipboardCommand}"
                                    Style="{StaticResource CopyButton}" />
                            <Button Content="キャンセル"
                                    Margin="12,0,0,0"
                                    Command="{Binding CancelCommand}"
                                    Style="{StaticResource CancelButton}"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- プレビュー -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardBorder}"
                    Padding="18"
                    VerticalAlignment="Stretch">
                <Grid VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- プレビューヘッダー -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="プレビュー"
                                       Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{Binding PageIndicator}"
                                       FontSize="12"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource MutedText}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="表示ページ"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Style="{StaticResource FieldLabel}" />
                            <TextBox Width="72"
                                     Text="{Binding PageNumber, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                            <Button Content="表示"
                                    Width="80"
                                    Margin="8,0,16,0"
                                    Command="{Binding GoToPageCommand}"
                                    Style="{StaticResource SecondaryButton}" />
                            <Button Content="＜"
                                    Width="32"
                                    Margin="0,0,8,0"
                                    ToolTip="前のページに移動"
                                    Command="{Binding PreviousPageCommand}"
                                    Style="{StaticResource SecondaryButton}" />
                            <Button Content="＞"
                                    Width="32"
                                    ToolTip="次のページに移動"
                                    Command="{Binding NextPageCommand}"
                                    Style="{StaticResource SecondaryButton}" />
                        </StackPanel>
                    </Grid>

                    <!-- プレビュー画像 -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource PreviewAreaBackgroundBrush}"
                            CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource PreviewAreaBorderBrush}"
                            Margin="0,14,0,0"
                            Padding="12"
                            VerticalAlignment="Stretch">
                        <Grid VerticalAlignment="Stretch">
                            <Image Source="{Binding PreviewImage}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />
                            <TextBlock Text="プレビュー画像がここに表示されます。PDFを選択すると自動でプレビューが表示されます。"
                                       FontSize="14"
                                       Padding="24"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource MutedText}"
                                       Visibility="{Binding PreviewImage, Converter={StaticResource NullToVisibilityConverter}}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

        </Grid>

        <!-- ステータスバー -->
        <StackPanel Grid.Row="2"
                    Margin="0,18,0,0">
            <ProgressBar Minimum="0"
                         Maximum="100"
                         Height="14"
                         Margin="0,0,0,10"
                         Value="{Binding ProgressValue}"
                         Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}" />
            <Border Padding="14"
                    Background="{DynamicResource StatusBarBackgroundBrush}"
                    CornerRadius="14"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource StatusBarForegroundBrush}"
                           VerticalAlignment="Center" />
            </Border>
        </StackPanel>

    </Grid>
</Window>
